#!/usr/bin/env sh
set -eu

make test
BUILD_VERSION="$(
  node -e "const fs=require('fs'); try { process.stdout.write(JSON.parse(fs.readFileSync('docs/version.json','utf8')).version || '0.1.0') } catch { process.stdout.write('0.1.0') }"
)"
BUILD_COMMIT="$(
  node -e "const fs=require('fs'); try { process.stdout.write(JSON.parse(fs.readFileSync('docs/version.json','utf8')).commit || 'dev') } catch { process.stdout.write('dev') }"
)"
make build VERSION="$BUILD_VERSION" COMMIT="$BUILD_COMMIT"
test -s docs/index.html
make smoke VERSION="$BUILD_VERSION" COMMIT="$BUILD_COMMIT"

if ! git diff --quiet -- docs; then
  echo 'The Pages build changed docs/. Run make build, commit docs/, and push again.'
  exit 1
fi
